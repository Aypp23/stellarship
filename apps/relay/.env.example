PORT=3001

# Soroban RPC endpoint (Testnet by default)
SOROBAN_RPC_URL="https://soroban-testnet.stellar.org"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed zk-battleship Soroban contract id (C...)
ZK_BATTLESHIP_CONTRACT_ID=""

# Relayer account secret key (S...) used to pay fees and submit end_game().
# Fund it on Testnet via Friendbot before using.
RELAYER_SECRET_KEY=""

# Bot account secret key (S...) used as Player 2 for "vs computer" mode.
# This account signs start_game (as source), commit_board, and commit_transcript.
BOT_SECRET_KEY=""

# Optional: override the prover binary path.
# Defaults to ../../proofs/zk-battleship-risc0/target/release/zkbs-prover when run from apps/relay.
ZKBS_PROVER_BIN=""

# Prover backend:
# - local: always run local zkbs-prover binary
# - github: always dispatch GitHub Actions workflow
# - auto: use GitHub when configured, otherwise local
ZKBS_PROVER_BACKEND="auto"

# GitHub Actions prover config (used when ZKBS_PROVER_BACKEND=github or auto with these set)
# Format: owner/repo
GITHUB_REPO="Aypp23/stellarship"
# Personal access token with repo + workflow scope for the target repository.
GITHUB_TOKEN=""
# Workflow file name or workflow id.
GITHUB_WORKFLOW="zkbs-prover.yml"
# Branch/ref where the workflow exists.
GITHUB_WORKFLOW_REF="main"
# Poll interval and max wait for workflow completion.
GITHUB_PROVER_POLL_MS="2500"
GITHUB_PROVER_TIMEOUT_MS="1200000"

# Optional: 4-byte selector prefix for Groth16 seals emitted by the prover.
# Keep in sync with deployed verifier selector in the router.
# Default in host binary is 73c457ba.
ZKBS_GROTH16_SELECTOR_HEX="73c457ba"
